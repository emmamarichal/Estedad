lookup ccmp_latn_2 {
	@CombiningTopAccents = [acutecomb brevecomb breveinvertedcomb caroncomb circumflexcomb dblgravecomb dblverticallineabovecomb dieresiscomb dotaccentcomb gravecomb hookabovecomb hungarumlautcomb macroncomb ringcomb tildecomb verticallineabovecomb];
	lookupflag UseMarkFilteringSet @CombiningTopAccents;
	sub i' @CombiningTopAccents by idotless;
	sub j' @CombiningTopAccents by jdotless;
} ccmp_latn_2;

lookup ccmp_latn_3 {
	lookupflag 0;
sub [d l L t] [caroncomb]' by [caroncomb.alt];
sub [D d G K L N R k l n r] [cedillacomb]' by [commaaccentcomb];
sub [g g.ss12] [cedillacomb]' by [commaturnedmod];
} ccmp_latn_3;

script latn;
lookup ccmp_latn_1;
lookup ccmp_latn_2;
lookup ccmp_latn_3;
";
tag = ccmp;
},
{
code = "# to support direct unicode input for other Arabic presentation forms:
lookup ccmp_arab_1 {
