},
{
code = "# Automatic Code End

#moving Dots:
#lookup movingDots {
#	script arab;
#	lookupflag 0;
#	pos [behDotless-ar.init behDotless-ar.medi] dotabove-ar behDotless-ar.medi twodotshorizontalbelow-ar' <80 0 0 0>;
#}movingDots;

#kerning marks:
lookup MovingMarksContextually {
	lookupflag UseMarkFilteringSet @belowMarks-ar;
	pos [behDotless-ar.init behDotless-ar.medi lam-ar.init lam-ar.medi lam-ar.medi.short] @belowMarks-ar' [yehFarsi-ar.fina yehFarsi-ar.fina.short] <120 0 0 0>;
} MovingMarksContextually;

#Moving hamzabelow and wavyhamzabelow after reh:
lookup MovingHamzaAfterReh {
	lookupflag UseMarkFilteringSet @hamzabelow;
	pos [reh-ar reh-ar.fina] [alef-ar alef-ar.short] [hamzabelow-ar wavyhamzabelow-ar]' <-100 0 0 0>;
} MovingHamzaAfterReh;

#Moving hamzabelow and wavyhamzabelow after yeh and peh:
lookup MovingHamzaAfteryeh {
	lookupflag 0;
	pos [behDotless-ar.init behDotless-ar.medi] [dotbelow-ar dotbelow-ar.ss01 dotbelow-ar.ss02 twodotshorizontalbelow-ar threedotsdownbelow-ar twodotshorizontalbelow-ar.ss01 threedotsdownbelow-ar.ss01 twodotshorizontalbelow-ar.ss02 threedotsdownbelow-ar.ss02 twodotshorizontalbelow-ar.ss03 threedotsdownbelow-ar.ss03] [alef-ar.fina alef-ar.fina.short] [hamzabelow-ar wavyhamzabelow-ar]' <-100 0 0 0>;
} MovingHamzaAfteryeh;

#kerning Strokes with other Strokes included Dots:
lookup KernWithDot {
	lookupflag UseMarkFilteringSet @BelowDots.wide;
	pos [reh-ar reh-ar.fina]' @BEH.init @BelowDots.wide <70 0 70 0>;
} KernWithDot;
lookup KernWithDot_ss01 {
	lookupflag UseMarkFilteringSet @BelowDots.wide.ss01;
	pos [reh-ar reh-ar.fina]' @BEH.init @BelowDots.wide.ss01 <70 0 70 0>;
} KernWithDot_ss01;
lookup KernWithDot_ss02 {
	lookupflag UseMarkFilteringSet @BelowDots.wide.ss02;
	pos [reh-ar reh-ar.fina]' @BEH.init @BelowDots.wide.ss02 <70 0 70 0>;
} KernWithDot_ss02;
lookup KernWithDot_ss03 {
	lookupflag UseMarkFilteringSet @BelowDots.wide.ss03;
	pos [reh-ar reh-ar.fina]' @BEH.init @BelowDots.wide.ss03 <70 0 70 0>;
} KernWithDot_ss03;

#Moving hamzabelow and wavyhamzabelow after yeh and peh:
lookup MovingHamzaAfterBehDotless.init {
	lookupflag 0;
	pos [behDotless-ar.init behDotless-ar.medi] hamzaabove-ar' <20 -60 0 0>;
} MovingHamzaAfterBehDotless.init;";
tag = mark;
}
);
