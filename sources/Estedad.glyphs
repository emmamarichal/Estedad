sub [number-ar year-ar footnotemarker-ar pagenumber-ar samvat-ar] @ArabicDigits'by @ArabicDigits.s;
} ccmp_arab_3;

script arab;
lookup ccmp_arab_1;
lookup ccmp_arab_2;
lookup ccmp_arab_3;

";
tag = ccmp;
},
{
code = "script arab;
  language URD  exclude_dflt;
