{
code = "#allah ligature:
lookup rlig_arab_0 {
	lookupflag 0;
	sub alef-ar lam-ar.init lam-ar.medi heh-ar.fina by allah-ar;
} rlig_arab_0;

#lam-alef ligatures:
lookup rlig_arab_1 {
	lookupflag IgnoreMarks;
	sub lam-ar.init alef-ar.fina.short by lam_alef-ar;
	sub lam-ar.init alef-ar.fina by lam_alef-ar;
	sub lam-ar.medi alef-ar.fina.short by lam_alef-ar.fina;
	sub lam-ar.medi alef-ar.fina by lam_alef-ar.fina;
} rlig_arab_1;

#shorter final yeh #1:
lookup rlig_arab_3_1 {
    lookupflag IgnoreMarks;
    sub [hah-ar.init seen-ar.init sad-ar.init tah-ar.init ain-ar.init fehDotless-ar.init keheh-ar.init gaf-ar.init.alt kafswash-ar.init lam-ar.init meem-ar.init heh-ar.init hehgoal-ar.init hah-ar.medi seen-ar.medi sad-ar.medi tah-ar.medi ain-ar.medi fehDotless-ar.medi keheh-ar.medi gaf-ar.medi.alt kafswash-ar.medi lam-ar.medi lam-ar.medi.short meem-ar.medi] yehFarsi-ar.fina'  by yehFarsi-ar.fina.short;
} rlig_arab_3_1;

#short hehgoal:
lookup rlig_arab_4 {
    lookupflag IgnoreMarks;
    sub hehgoal-ar.init' [alef-ar.fina alef-ar.fina.short highhamzaAlef-ar.fina kaf-ar.fina keheh-ar.fina gaf-ar.fina.alt keheh-ar.medi gaf-ar.medi.alt lam-ar.fina lam-ar.medi lam-ar.medi.short lam_alef-ar.fina lamDoublebar_alef-ar.fina.rlig lamBar_alef-ar.fina.rlig ]  by hehgoal-ar.init.short;
} rlig_arab_4;

#hamzaabove to minikeheh after heh/heh.fina:
lookup rlig_arab_6 {
  lookupflag RightToLeft;
    sub heh-ar hamzaabove-ar' by miniKeheh-ar;
    sub heh-ar.fina hamzaabove-ar' by miniKeheh-ar.afterhehfina;
} rlig_arab_6;

#Shorter yeh/peh-ar.medi and similar glyphs:
#lookup rlig_arab_7 {
#    lookupflag UseMarkFilteringSet @BelowDots;
#    sub @BeforeYehShort behDotless-ar.medi' @AfterYehShort by behDotless-ar.medi.shortYeh;
#} rlig_arab_7;


#Extended initial glyphs in dot below glyphs:
lookup rlig_arab_8 {
    lookupflag UseMarkFilteringSet @BelowDots;
    sub [behDotless-ar.init behDotless-ar.medi]' @BelowDots.narrow [yehFarsi-ar.fina yehTail-ar.fina waw-ar.fina qafDotless-ar.fina wawStraight-ar.fina]  by [behDotless-ar.init.Extended_1 behDotless-ar.medi.Extended_1];

    sub [behDotless-ar.init behDotless-ar.medi]' @BelowDots.narrow [ain-ar.fina hah-ar.fina]  by [behDotless-ar.init.Extended_2 behDotless-ar.medi.Extended_2];
	
    sub [behDotless-ar.init behDotless-ar.medi]' @BelowDots.wide [yehFarsi-ar.fina yehTail-ar.fina]  by [behDotless-ar.init.Extended_3 behDotless-ar.medi.Extended_3];
	
    sub [behDotless-ar.init lam-ar.init behDotless-ar.medi lam-ar.medi]' @BelowDots.wide [hah-ar.fina hehgoal-ar.medi hehDoachashmee-ar.medi ain-ar.fina qafDotless-ar.fina heh-ar.medi waw-ar.fina alefWavyhamzabelow-ar.fina]  by [behDotless-ar.init.Extended_2 lam-ar.init.Extended_3 behDotless-ar.medi.Extended_2 lam-ar.medi.Extended_3];
	
    sub [behDotless-ar.init behDotless-ar.medi]' @BelowDots.wide [reh-ar.fina noonghunna-ar.fina lam-ar.fina]  by [behDotless-ar.init.Extended_1 behDotless-ar.medi.Extended_1];
} rlig_arab_8;

#shorter yehBarree fina:
lookup rlig_arab_9 {
	lookupflag UseMarkFilteringSet @BelowDots.wide;
    sub [behDotless-ar.init behDotless-ar.init.Extended_1 behDotless-ar.init.Extended_2 behDotless-ar.init.Extended_3 behDotless-ar.medi behDotless-ar.medi.Extended_1 behDotless-ar.medi.Extended_2 behDotless-ar.medi.Extended_3] @BelowDots.wide yehbarree-ar.fina' by yehbarree-ar.fina.short;
} rlig_arab_9;

#shorter final yeh #2:
lookup rlig_arab_3_2 {
    lookupflag IgnoreMarks;
    sub [behDotless-ar.init behDotless-ar.medi] yehFarsi-ar.fina'  by yehFarsi-ar.fina.short;
} rlig_arab_3_2;
";
