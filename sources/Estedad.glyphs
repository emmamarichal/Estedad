# numbers after endofayah-ar, number-ar,year-ar, footnotemarker-ar, pagenumber-ar and samvat-ar:
lookup ccmp_arab_3 {
lookupflag 0;
sub [endofayah-ar] @ArabicDigits.EoA @ArabicDigits.EoA @ArabicDigits'by @ArabicDigits.EoA;
